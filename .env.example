# Exemple de configuration d'environnement
# Copier ce fichier vers ".env" et adapter les valeurs

APP_ENV=dev
# Environnement de l'application (dev, prod, test)

DB_HOST=db
# Nom du service MySQL défini dans docker-compose

DB_NAME=ecoride
# Nom de la base de données

DB_USER=your_db_user
# Utilisateur MySQL utilisé par l'application

DB_PASS=your_db_password
# Mot de passe de l'utilisateur MySQL

DB_PORT=3306
# Port MySQL dans le réseau Docker

DB_ROOT_PASS=your_root_password
# Mot de passe root MySQL (utilisé uniquement par le conteneur)

MONGO_HOST=mongo
# Nom du service MongoDB dans docker-compose

MONGO_PORT=27017
# Port MongoDB

MONGO_DB=ecoride_nosql
# Base MongoDB utilisée par l'application

MONGO_COLLECTION_ACTIVITY=activity_logs
# Collection utilisée pour les logs d'activité

PLATFORM_USER_ID=1
# Identifiant de l'utilisateur système utilisé par l'application